{
  "version": 1,
  "repositories": {
    "arckit": {
      "summary": "ArcKit — enterprise architecture governance toolkit (skills, agents, commands, MCP, hooks) for Claude Code.",
      "source": {
        "type": "git",
        "url": "https://github.com/tractorjuice/arc-kit",
        "ref": "main",
        "subdir": "plugins/arckit-claude"
      },
      "target_profiles": {
        "claude": {
          "hook": {
            "strategy": "link+merge",
            "dest": ".claude/hooks/agentry/{repo}@{ref}/{name}",
            "file": ".claude/settings.json",
            "pointer": "hooks",
            "rewrite_from": "${CLAUDE_PLUGIN_ROOT}/hooks",
            "rewrite_to": "${CLAUDE_PROJECT_DIR}/.claude/hooks/agentry/{repo}@{ref}/{name}"
          }
        }
      }
    },
    "ui-ux-pro-max": {
      "summary": "UI/UX design intelligence: 50+ styles, color palettes, font pairings, UX guidelines across 10 stacks.",
      "source": {
        "type": "git",
        "url": "https://github.com/nextlevelbuilder/ui-ux-pro-max-skill",
        "ref": "main"
      },
      "expose": [
        {
          "type": "skill",
          "name": "ui-ux-pro-max",
          "path": ".claude/skills/ui-ux-pro-max"
        }
      ]
    },
    "graphify": {
      "summary": "Turn a codebase into a navigable knowledge graph.",
      "source": {
        "type": "git",
        "url": "https://github.com/safishamsi/graphify",
        "ref": "main"
      },
      "expose": [
        {
          "type": "skill",
          "name": "graphify",
          "generate": {
            "setup": [
              [
                "uv",
                "tool",
                "install",
                "graphifyy"
              ]
            ],
            "command": [
              "graphify",
              "install",
              "--project"
            ],
            "produces": [
              ".claude/skills/graphify"
            ]
          }
        }
      ]
    },
    "superpowers": {
      "summary": "Superpowers — a library of process skills (TDD, debugging, planning, code review) plus a SessionStart hook that surfaces them.",
      "source": {
        "type": "git",
        "url": "https://github.com/obra/superpowers",
        "ref": "main"
      },
      "target_profiles": {
        "claude": {
          "hook": {
            "strategy": "link+merge",
            "dest": ".claude/hooks/agentry/{repo}@{ref}/{name}",
            "file": ".claude/settings.json",
            "pointer": "hooks",
            "rewrite_from": "${CLAUDE_PLUGIN_ROOT}/hooks",
            "rewrite_to": "${CLAUDE_PROJECT_DIR}/.claude/hooks/agentry/{repo}@{ref}/{name}"
          }
        }
      }
    },
    "ponytail": {
      "summary": "Ponytail — guides agents to write minimal, necessary code via a 'laziness ladder' (YAGNI, reuse, stdlib, then minimum).",
      "source": {
        "type": "git",
        "url": "https://github.com/DietrichGebert/ponytail",
        "ref": "main"
      }
    },
    "caveman": {
      "summary": "Caveman — compresses agent output by ~65% using caveman-style speech while preserving technical accuracy.",
      "source": {
        "type": "git",
        "url": "https://github.com/juliusbrussee/caveman",
        "ref": "main"
      }
    },
    "markitdown-for-ai": {
      "summary": "MarkItDown4AI — converts documents (PDF, DOCX, PPTX, XLSX, HTML) to Markdown for AI agents.",
      "source": {
        "type": "git",
        "url": "https://github.com/OpenTechIL/markitdown-for-ai",
        "ref": "main"
      },
      "expose": [
        {
          "type": "skill",
          "name": "document-to-markdown",
          "path": "skills/document-to-markdown"
        }
      ]
    },
    "use-agentry": {
      "summary": "Teaches AI tools to route 'add skill <url>' and pasted 'npx skills add …' requests through agentry (agy), so skills stay tracked in .agentry.yml/.agentry.lock.",
      "source": {
        "type": "git",
        "url": "https://github.com/OpenTechIL/agentry",
        "ref": "main"
      },
      "expose": [
        {
          "type": "skill",
          "name": "use-agentry",
          "path": "skills/use-agentry"
        }
      ]
    }
  }
}
